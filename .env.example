# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./demo.db

# API / security
SECRET_KEY=your_secret_key_here
SKIP_INIT_DATA_VALIDATION=false

# Admin (comma-separated Telegram user IDs)
ADMIN_IDS=123456789

# Демо для клиента: true = /admin в меню у всех и доступ без ADMIN_IDS (только тест!)
DEMO_MODE=false

# Mini App base URL (https, e.g. ngrok)
WEBAPP_URL=https://your-subdomain.ngrok-free.app

# Optional: extra CORS origins comma-separated (defaults to WEBAPP_URL host)
# CORS_ORIGINS=https://a.ngrok-free.app,https://b.ngrok-free.app

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false
LOG_JSON=false
